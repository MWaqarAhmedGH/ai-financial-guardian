{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/analyze", "dest": "server.js" },
    { "src": "/execute-action", "dest": "server.js" },
    { "src": "/chat", "dest": "server.js" },
    { "src": "/api-status", "dest": "server.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}